{
  "name": "opengram-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Opengram monorepo",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/docs",
    "apps/demo-video",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w apps/web run dev",
    "build": "npm -w apps/web run build",
    "test": "npm -w apps/web run test",
    "lint": "npm -w apps/web run lint",
    "typecheck": "npm -w apps/web run typecheck",
    "docs:dev": "npm -w apps/docs run dev",
    "docs:build": "npm -w apps/docs run build",
    "release": "npx --silent tsx scripts/release.ts"
  }
}
