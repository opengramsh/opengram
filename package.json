{
  "name": "opengram",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"tsx --watch src/server.ts\" \"vite --host 0.0.0.0 --port 5173\"",
    "dev:server": "tsx --watch src/server.ts",
    "dev:client": "vite",
    "build": "vite build && tsup src/server.ts --format esm --outDir dist/server",
    "start": "node dist/server/server.mjs",
    "db:migrate": "node deploy/docker/run-migrations.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "facehash": "^0.1.0",
    "hono": "^4.12.0",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "wasm-vips": "^0.0.16"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "minimatch": "^10.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
