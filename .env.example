# SQLite database file path.
DATABASE_URL=./data/opengram.db

# Development|production runtime mode.
NODE_ENV=development

# Optional override for the OpenGram JSON config file.
OPENGRAM_CONFIG_PATH=./config/opengram.config.json

# Public URL used for deep links and push payloads.
OPENGRAM_PUBLIC_BASE_URL=http://localhost:3000

# Optional API write protection.
OPENGRAM_INSTANCE_SECRET=

# Web Push VAPID configuration (required only when push.enabled=true).
OPENGRAM_VAPID_PUBLIC_KEY=
OPENGRAM_VAPID_PRIVATE_KEY=
OPENGRAM_VAPID_SUBJECT=mailto:admin@example.com
