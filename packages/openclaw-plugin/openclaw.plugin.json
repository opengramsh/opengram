{
  "id": "openclaw-plugin-opengram",
  "name": "opengram",
  "version": "0.1.0",
  "description": "OpenGram channel plugin for OpenClaw — mobile-first AI agent chat interface",
  "author": "Brice Ventures",
  "license": "MIT",
  "channels": ["opengram"],
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://localhost:3000",
        "description": "OpenGram instance URL (e.g., http://localhost:3000)"
      },
      "instanceSecret": {
        "type": "string",
        "description": "OpenGram instance secret for API auth (if security is enabled)"
      },
      "defaultModelId": {
        "type": "string",
        "description": "Default model ID for chats created in OpenGram"
      },
      "reconnectDelayMs": {
        "type": "number",
        "default": 3000,
        "description": "SSE reconnect delay in ms after connection loss"
      },
      "agents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Linked OpenClaw agent IDs"
      },
      "autoRename": {
        "type": "object",
        "description": "Automatic chat renaming based on conversation content",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable automatic chat renaming"
          },
          "provider": {
            "type": "string",
            "enum": ["anthropic", "openai", "google", "xai", "openrouter"],
            "description": "AI provider for title generation"
          },
          "modelId": {
            "type": "string",
            "description": "Model ID to use for title generation"
          },
          "apiKey": {
            "type": "string",
            "description": "API key (leave empty to use environment variable)"
          }
        }
      }
    },
    "required": []
  },
  "uiHints": {
    "baseUrl": {
      "label": "OpenGram URL",
      "placeholder": "http://localhost:3000"
    },
    "instanceSecret": {
      "label": "Instance Secret",
      "sensitive": true
    },
    "defaultModelId": {
      "label": "Default Model ID",
      "placeholder": "claude-opus-4-6"
    },
    "reconnectDelayMs": {
      "label": "Reconnect Delay (ms)"
    },
    "agents": {
      "label": "Linked Agents"
    },
    "autoRename": {
      "label": "Auto Rename",
      "apiKey": { "sensitive": true }
    }
  }
}
